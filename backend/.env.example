# Finnhub API key (free tier: https://finnhub.io/register).
# The free tier streams live US-equity TRADES for MU. Get a key, paste it
# below, then restart the backend. NEVER commit ".env".
FINNHUB_API_KEY=your_finnhub_api_key_here

# Optional: override the frontend origin allowed by CORS (default http://localhost:3000)
# FRONTEND_ORIGIN=http://localhost:3000

# Optional: override the SQLite DB file location (default: backend/market_data.db)
# MARKET_DB_PATH=./market_data.db

# Optional: override the default tracked symbol (default: MU)
# SYMBOL=AAPL

# Optional: override the default market (default: US)
# MARKET=US
